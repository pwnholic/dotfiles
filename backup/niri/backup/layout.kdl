// ============================================================================
//  Layout: gaps, focus ring, shadow, column widths
//  Docs: https://github.com/YaLTeR/niri/wiki/Configuration:-Layout
// ----------------------------------------------------------------------------
//  Because this file is *included* (not the main config), the historical
//  "write an empty border {} block to enable it" shortcut does not apply. We
//  enable shadow and focus-ring explicitly with `on`.
// ============================================================================

layout {
    gaps 10
    center-focused-column "never"

    // Transparent so Noctalia's wallpaper layer shows through empty workspaces.
    // Keep this, or the wallpaper disappears behind the workspace background.
    background-color "transparent"

    // Accent ring around the active window - Tokyo Night palette:
    //   blue #7aa2f7 | cyan #7dcfff | magenta #bb9af7 | red #f7768e
    //   orange #ff9e64 | yellow #e0af68 | green #9ece6a | muted #414868
    focus-ring {
        on
        width 2
        active-gradient from="#7aa2f7" to="#bb9af7" angle=45
        inactive-color "#414868"   // muted "terminal black"
        urgent-color "#f7768e"     // attention requests
    }

    // Drop hint while interactively moving a window; matches the accent.
    insert-hint {
        color "#7aa2f780"
    }

    // Soft drop shadow behind every window. It follows the corner radius set
    // in window-rules.kdl (geometry-corner-radius).
    shadow {
        on
        softness 30
        spread 4
        offset x=0 y=4
        color "#00000070"
        inactive-color "#00000040"
    }

    // Widths cycled by switch-preset-column-width (Mod+R by default).
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    // Outer gaps reserved for panels. Noctalia reserves its own exclusive zone,
    // so these stay empty. Add values (e.g. top 48) only if a panel overlaps
    // your windows.
    struts {}
}

// ---- Overview appearance ----------------------------------------------------
// Docs: https://github.com/YaLTeR/niri/wiki/Configuration:-Miscellaneous#overview
overview {
    zoom 0.5
    backdrop-color "#16161e" // Tokyo Night bg_dark
    workspace-shadow {
        softness 40
        spread 10
        offset x=0 y=10
        color "#00000090"
    }
}
