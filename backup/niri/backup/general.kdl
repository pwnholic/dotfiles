// ============================================================================
//  General / top-level options
//  Docs: https://github.com/YaLTeR/niri/wiki/Configuration:-Miscellaneous
// ============================================================================

// Ask apps to drop client-side decorations so niri draws its own clean borders
// and shadows. Restart already-running apps after changing this for full effect.
prefer-no-csd

// Where niri's built-in screenshot actions save to disk. It is null here because
// screenshots are handled by Noctalia / your own tools. To also save them:
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// Environment for processes spawned by niri.
//
// NVIDIA NOTE: niri's official wiki does NOT recommend any special GL/GBM env
// vars here. Niri talks EGL/GBM to the driver directly, and on this hybrid
// (Intel + NVIDIA) machine niri already renders on the NVIDIA dGPU (verified
// via its loaded libEGL_nvidia + /dev/dri nodes). Legacy vars such as
// GBM_BACKEND=nvidia-drm or __GL_GSYNC_ALLOWED are unnecessary and can even
// break the hybrid setup, so they are intentionally omitted.
environment {
    ELECTRON_OZONE_PLATFORM_HINT "auto" // Chromium/Electron pick Wayland or X11 automatically
    QT_QPA_PLATFORM "wayland"           // Qt apps default to the Wayland backend
    QT_QPA_PLATFORMTHEME "gtk3"         // Qt follows the GTK3 theme
    QT_WAYLAND_DISABLE_WINDOWDECORATION "1"
    XDG_CURRENT_DESKTOP "niri"
    XDG_SESSION_TYPE "wayland"
    MOZ_ENABLE_WAYLAND "1" // Firefox: enable Wayland rendering
}

cursor {
    xcursor-theme "capitaine-cursors"
    xcursor-size 24
    // hide-when-typing            // hide the cursor while typing (can bother some games)
    // hide-after-inactive-ms 1000 // auto-hide the cursor after 1s of no movement
}

// Required for Noctalia: lets its notification actions and window-activation
// requests work even though they arrive with an invalid activation serial.
debug {
    honor-xdg-activation-with-invalid-serial
}

// Spawn xwayland-satellite on demand for X11-only apps (handled automatically).
xwayland-satellite {
    path "/usr/bin/xwayland-satellite"
}

hotkey-overlay {
    skip-at-startup
}
